{"slug": "down-payment-help", "card": {"html": "<!DOCTYPE html> <html> <head> <meta charset='utf-8'> <style> * { margin: 0; padding: 0; box-sizing: border-box; } html, body { width: 1080px; height: 1350px; overflow: hidden; } body { background: linear-gradient(160deg, #0d1f33 0%, #122c47 100%); font-family: Georgia, 'Times New Roman', serif; color: #ffffff; position: relative; } .frame { position: absolute; top: 36px; left: 36px; right: 36px; bottom: 36px; border: 2px solid rgba(197, 165, 90, 0.55); display: flex; flex-direction: column; align-items: center; padding: 64px 70px 48px 70px; } .logo { width: 216px; margin-bottom: 40px; } .eyebrow { font-family: Georgia, serif; font-size: 26px; letter-spacing: 7px; color: #c5a55a; text-transform: uppercase; margin-bottom: 44px; } h1 { font-size: 92px; line-height: 1.12; text-align: center; font-weight: normal; margin-bottom: 52px; } h1 .gold { color: #c5a55a; } .rule { width: 120px; height: 3px; background: #c5a55a; margin-bottom: 54px; } .row { width: 100%; margin-bottom: 42px; text-align: center; } .row .label { font-size: 30px; letter-spacing: 4px; text-transform: uppercase; color: #c5a55a; margin-bottom: 10px; } .row .big { font-size: 54px; line-height: 1.15; margin-bottom: 8px; } .row .sub { font-size: 33px; color: #d9e2ec; font-style: italic; } .question { margin-top: auto; font-size: 43px; font-style: italic; color: #c5a55a; margin-bottom: 42px; text-align: center; line-height: 1.25; } .footer { font-family: Arial, Helvetica, sans-serif; font-size: 24px; color: #aebdcc; letter-spacing: 0.5px; } </style> </head> <body> <div class='frame'> <img class='logo' src='../../assets/phr_logo_white.png' alt=''> <div class='eyebrow'>Hometown Heroes, Reopened</div> <h1>Up to <span class='gold'>$35,000</span> toward your first home.</h1> <div class='rule'></div> <div class='row'> <div class='label'>Who It Is For</div> <div class='big'>Frontline first-time buyers.</div> <div class='sub'>Teachers, nurses, deputies, firefighters.</div> </div> <div class='row'> <div class='label'>The Catch</div> <div class='big'>First come, first served.</div> <div class='sub'>$50 million, and it will not last.</div> </div> <div class='question'>Think you qualify? Let's talk before it is gone.</div> <div class='footer'>Roger Averbuj, Broker | Prestige Heritage Realty | (954) 663-8461</div> </div> </body> </html>", "width": 1080, "height": 1350}, "video": {"html": "<!DOCTYPE html> <html> <head> <meta charset='utf-8'> <style> * { margin: 0; padding: 0; box-sizing: border-box; } html, body { width: 1080px; height: 1920px; overflow: hidden; } body { background: linear-gradient(160deg, #0d1f33 0%, #122c47 100%); font-family: Georgia, 'Times New Roman', serif; color: #ffffff; } .scene { position: absolute; top: 0; left: 0; width: 1080px; height: 1920px; display: flex; flex-direction: column; align-items: center; justify-content: center; text-align: center; padding: 0 90px; opacity: 0; } .kicker { font-size: 34px; letter-spacing: 8px; text-transform: uppercase; color: #c5a55a; margin-bottom: 48px; font-family: Georgia, serif; } .line { font-size: 94px; line-height: 1.14; font-weight: normal; } .line .gold { color: #c5a55a; } .huge { font-size: 150px; line-height: 1.05; } .num { font-size: 190px; color: #c5a55a; line-height: 1; margin: 26px 0 24px 0; } .sub { font-size: 56px; font-style: italic; color: #d9e2ec; margin-top: 34px; } .bar { width: 140px; height: 4px; background: #c5a55a; margin: 44px auto 0 auto; } .endlogo { width: 300px; margin-bottom: 70px; } .tagline { font-size: 84px; line-height: 1.2; } .endfooter { font-family: Arial, Helvetica, sans-serif; font-size: 30px; color: #aebdcc; margin-top: 90px; line-height: 1.6; } </style> </head> <body> <div class='scene' id='s0'> <div class='kicker'>Broward County</div> <div class='line'>Florida just reopened <span class='gold'>$50 million</span> in homebuyer help.</div> </div> <div class='scene' id='s1'> <div class='line'>Built for the people who keep this county <span class='gold'>running.</span></div> </div> <div class='scene' id='s2'> <div class='kicker'>Who It Is For</div> <div class='line'>Teachers. Nurses. Deputies. <span class='gold'>Firefighters.</span></div> </div> <div class='scene' id='s3'> <div class='kicker'>What You Get</div> <div class='num'>$35,000</div> <div class='line'>toward your down payment and closing costs.</div> </div> <div class='scene' id='s4'> <div class='line huge'>Zero <span class='gold'>interest.</span></div> <div class='sub'>Nothing owed until you sell.</div> </div> <div class='scene' id='s5'> <div class='kicker'>The Catch</div> <div class='line huge'>First come, <span class='gold'>first served.</span></div> </div> <div class='scene' id='s6'> <div class='line'>When the money is gone, <span class='gold'>it is gone.</span></div> <div class='sub'>This round could last months, not years.</div> </div> <div class='scene' id='s7'> <div class='line'>Think you might qualify? <span class='gold'>Ask before the door closes.</span></div> <div class='bar'></div> </div> <div class='scene' id='s8'> <img class='endlogo' src='../../assets/phr_logo_white.png' alt=''> <div class='tagline'>Straight answers.<br><span class='gold'>Deep roots.</span></div> <div class='endfooter'>Roger Averbuj, Broker<br>Prestige Heritage Realty<br>(954) 663-8461</div> </div> <script> var TIMES = [ [0.0, 2.6], [2.6, 4.8], [4.8, 7.4], [7.4, 10.2], [10.2, 12.4], [12.4, 15.0], [15.0, 17.8], [17.8, 20.0], [20.0, 23.0] ]; var IN_D = 0.32; var OUT_D = 0.22; function clamp(x, a, b) { return Math.max(a, Math.min(b, x)); } function easeOut(p) { return 1 - Math.pow(1 - p, 3); } function seek(t) { for (var i = 0; i < TIMES.length; i++) { var el = document.getElementById('s' + i); var st = TIMES[i][0], en = TIMES[i][1]; var op = 0, ty = 0, sc = 1; if (t >= st && t < en) { var pIn = clamp((t - st) / IN_D, 0, 1); var pOut = (i === TIMES.length - 1) ? 1 : clamp((en - t) / OUT_D, 0, 1); var e = easeOut(pIn); op = Math.min(e, pOut); ty = (1 - e) * 46; sc = 0.97 + 0.03 * e; } el.style.opacity = op; el.style.transform = 'translateY(' + ty + 'px) scale(' + sc + ')'; } var pops = [[3, 7.4]]; for (var j = 0; j < pops.length; j++) { var idx = pops[j][0], start = pops[j][1]; var numEl = document.querySelector('#s' + idx + ' .num'); if (!numEl) continue; var p = clamp((t - start - 0.15) / 0.45, 0, 1); var s = 0.6 + 0.4 * easeOut(p); numEl.style.opacity = p; numEl.style.transform = 'scale(' + s + ')'; } } window.seek = seek; seek(0); </script> </body> </html>", "width": 1080, "height": 1920, "fps": 25, "duration": 23.0}}
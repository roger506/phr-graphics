  "html": "<!DOCTYPE html>\n<html>\n<head>\n<meta charset=\"utf-8\">\n<style>\n  * { margin: 0; padding: 0; box-sizing: border-box; }\n  html, body { width: 1080px; height: 1350px; overflow: hidden; }\n  body {\n    background: linear-gradient(160deg, #0d1f33 0%, #122c47 100%);\n    font-family: Georgia, 'Times New Roman', serif;\n    color: #ffffff;\n    position: relative;\n  }\n  .frame {\n    position: absolute; top: 36px; left: 36px; right: 36px; bottom: 36px;\n    border: 2px solid rgba(197, 165, 90, 0.55);\n    display: flex; flex-direction: column; align-items: center;\n    padding: 64px 70px 48px 70px;\n  }\n  .logo { width: 216px; margin-bottom: 40px; }\n  .eyebrow {\n    font-family: Georgia, serif; font-size: 26px; letter-spacing: 7px;\n    color: #c5a55a; text-transform: uppercase; margin-bottom: 44px;\n  }\n  h1 {\n    font-size: 92px; line-height: 1.12; text-align: center;\n    font-weight: normal; margin-bottom: 52px;\n  }\n  h1 .gold { color: #c5a55a; }\n  .rule { width: 120px; height: 3px; background: #c5a55a; margin-bottom: 56px; }\n  .row { width: 100%; margin-bottom: 44px; text-align: center; }\n  .row .label {\n    font-size: 30px; letter-spacing: 4px; text-transform: uppercase;\n    color: #c5a55a; margin-bottom: 10px;\n  }\n  .row .big { font-size: 54px; line-height: 1.15; margin-bottom: 8px; }\n  .row .sub { font-size: 34px; color: #d9e2ec; font-style: italic; }\n  .question {\n    margin-top: auto; font-size: 46px; font-style: italic; color: #c5a55a;\n    margin-bottom: 42px;\n  }\n  .footer {\n    font-family: Arial, Helvetica, sans-serif;\n    font-size: 24px; color: #aebdcc; letter-spacing: 0.5px;\n  }\n</style>\n</head>\n<body>\n  <div class=\"frame\">\n    <img class=\"logo\" src=\"../../assets/phr_logo_white.png\" alt=\"\">\n    <div class=\"eyebrow\">Broward County &bull; The June Numbers</div>\n    <h1>Broward is <span class=\"gold\">two markets</span> right now.</h1>\n    <div class=\"rule\"></div>\n    <div class=\"row\">\n      <div class=\"label\">Single Family</div>\n      <div class=\"big\">4.3 months of supply.</div>\n      <div class=\"sub\">Sellers still hold the cards.</div>\n    </div>\n    <div class=\"row\">\n      <div class=\"label\">Condos</div>\n      <div class=\"big\">10.1 months of supply.</div>\n      <div class=\"sub\">Buyers finally have leverage.</div>\n    </div>\n    <div class=\"question\">Which one are you in?</div>\n    <div class=\"footer\">Roger Averbuj, Broker | Prestige Heritage Realty | (954) 663-8461</div>\n  </div>\n</body>\n</html>\n",

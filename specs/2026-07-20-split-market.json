 "video": {
  "html": "<!DOCTYPE html>\n<html>\n<head>\n<meta charset=\"utf-8\">\n<style>\n  * { margin: 0; padding: 0; box-sizing: border-box; }\n  html, body { width: 1080px; height: 1920px; overflow: hidden; }\n  body {\n    background: linear-gradient(160deg, #0d1f33 0%, #122c47 100%);\n    font-family: Georgia, 'Times New Roman', serif;\n    color: #ffffff;\n  }\n  .scene {\n    position: absolute; top: 0; left: 0; width: 1080px; height: 1920px;\n    display: flex; flex-direction: column; align-items: center;\n    justify-content: center; text-align: center;\n    padding: 0 90px; opacity: 0;\n  }\n  .kicker {\n    font-size: 34px; letter-spacing: 8px; text-transform: uppercase;\n    color: #c5a55a; margin-bottom: 48px; font-family: Georgia, serif;\n  }\n  .line { font-size: 96px; line-height: 1.14; font-weight: normal; }\n  .line .gold { color: #c5a55a; }\n  .huge { font-size: 170px; line-height: 1.05; }\n  .num { font-size: 210px; color: #c5a55a; line-height: 1; margin: 30px 0 26px 0; }\n  .sub { font-size: 58px; font-style: italic; color: #d9e2ec; margin-top: 34px; }\n  .bar { width: 140px; height: 4px; background: #c5a55a; margin: 44px auto 0 auto; }\n  .endlogo { width: 300px; margin-bottom: 70px; }\n  .tagline { font-size: 84px; line-height: 1.2; }\n  .endfooter {\n    font-family: Arial, Helvetica, sans-serif; font-size: 30px;\n    color: #aebdcc; margin-top: 90px; line-height: 1.6;\n  }\n</style>\n</head>\n<body>\n  <div class=\"scene\" id=\"s0\">\n    <div class=\"kicker\">Broward County</div>\n    <div class=\"line\">Home sales just rose for the <span class=\"gold\">4th straight month.</span></div>\n  </div>\n  <div class=\"scene\" id=\"s1\">\n    <div class=\"line\">The headlines will call this market <span class=\"gold\">hot.</span></div>\n  </div>\n  <div class=\"scene\" id=\"s2\">\n    <div class=\"line huge\"><span class=\"gold\">Half true.</span></div>\n  </div>\n  <div class=\"scene\" id=\"s3\">\n    <div class=\"line\">Broward is <span class=\"gold\">two markets</span> right now.</div>\n    <div class=\"bar\"></div>\n  </div>\n  <div class=\"scene\" id=\"s4\">\n    <div class=\"kicker\">Single Family</div>\n    <div class=\"num\">4.3</div>\n    <div class=\"line\">months of supply.</div>\n    <div class=\"sub\">Sellers still hold the cards.</div>\n  </div>\n  <div class=\"scene\" id=\"s5\">\n    <div class=\"kicker\">Condos</div>\n    <div class=\"num\">10.1</div>\n    <div class=\"line\">months of supply.</div>\n    <div class=\"sub\">Buyers finally have leverage.</div>\n  </div>\n  <div class=\"scene\" id=\"s6\">\n    <div class=\"line\">The expensive mistake is playing the <span class=\"gold\">wrong side.</span></div>\n  </div>\n  <div class=\"scene\" id=\"s7\">\n    <div class=\"line\">Know <span class=\"gold\">which market</span> you are in.</div>\n  </div>\n  <div class=\"scene\" id=\"s8\">\n    <img class=\"endlogo\" src=\"../../assets/phr_logo_white.png\" alt=\"\">\n    <div class=\"tagline\">Straight answers.<br><span class=\"gold\">Deep roots.</span></div>\n    <div class=\"endfooter\">Roger Averbuj, Broker<br>Prestige Heritage Realty<br>(954) 663-8461</div>\n  </div>\n\n<script>\n  // Scene timing: [start, end] seconds. Total 24.0s, brisk pacing.\n  var TIMES = [\n    [0.0, 2.6],\n    [2.6, 5.0],\n    [5.0, 6.6],\n    [6.6, 9.4],\n    [9.4, 12.8],\n    [12.8, 16.2],\n    [16.2, 19.0],\n    [19.0, 21.2],\n    [21.2, 24.0]\n  ];\n  var IN_D = 0.32;   // fade/slide in duration\n  var OUT_D = 0.22;  // fade out duration\n\n  function clamp(x, a, b) { return Math.max(a, Math.min(b, x)); }\n  function easeOut(p) { return 1 - Math.pow(1 - p, 3); }\n\n  function seek(t) {\n    for (var i = 0; i < TIMES.length; i++) {\n      var el = document.getElementById('s' + i);\n      var st = TIMES[i][0], en = TIMES[i][1];\n      var op = 0, ty = 0, sc = 1;\n      if (t >= st && t < en) {\n        var pIn = clamp((t - st) / IN_D, 0, 1);\n        var pOut = (i === TIMES.length - 1) ? 1 : clamp((en - t) / OUT_D, 0, 1);\n        var e = easeOut(pIn);\n        op = Math.min(e, pOut);\n        ty = (1 - e) * 46;\n        sc = 0.97 + 0.03 * e;\n      }\n      el.style.opacity = op;\n      el.style.transform = 'translateY(' + ty + 'px) scale(' + sc + ')';\n    }\n    // Number pop on stat scenes\n    var pops = [[4, 9.4], [5, 12.8]];\n    for (var j = 0; j < pops.length; j++) {\n      var idx = pops[j][0], start = pops[j][1];\n      var numEl = document.querySelector('#s' + idx + ' .num');\n      if (!numEl) continue;\n      var p = clamp((t - start - 0.15) / 0.45, 0, 1);\n      var s = 0.6 + 0.4 * easeOut(p);\n      numEl.style.opacity = p;\n      numEl.style.transform = 'scale(' + s + ')';\n    }\n  }\n  seek(0);\n</script>\n</body>\n</html>\n",

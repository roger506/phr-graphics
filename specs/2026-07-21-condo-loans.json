    "html": "<!DOCTYPE html>\n<html>\n<head>\n<meta charset=\"utf-8\">\n<style>\n  * { margin: 0; padding: 0; box-sizing: border-box; }\n  body { width: 1080px; height: 1920px; overflow: hidden; background: #0d1f33; }\n  .stage {\n    width: 1080px; height: 1920px;\n    background: linear-gradient(165deg, #0d1f33 0%, #122c47 100%);\n    font-family: Georgia, 'Times New Roman', serif;\n    color: #ffffff; position: relative; overflow: hidden;\n  }\n  .scene {\n    position: absolute; inset: 0;\n    display: flex; flex-direction: column; justify-content: center; align-items: center;\n    text-align: center; padding: 0 90px; opacity: 0;\n  }\n  .scene .big { font-size: 130px; line-height: 1.12; }\n  .scene .mid { font-size: 96px; line-height: 1.18; }\n  .scene .gold { color: #c5a55a; }\n  .kicker {\n    font-family: Arial, Helvetica, sans-serif; font-weight: bold;\n    font-size: 34px; letter-spacing: 8px; text-transform: uppercase;\n    color: #c5a55a; margin-bottom: 48px;\n  }\n  .rule { width: 150px; height: 6px; background: #c5a55a; margin: 52px auto 0 auto; }\n  .stack { font-size: 120px; line-height: 1.35; }\n  .endlogo { width: 340px; margin-bottom: 70px; }\n  .tagline { font-size: 92px; line-height: 1.2; margin-bottom: 60px; }\n  .compliance {\n    font-family: Arial, Helvetica, sans-serif;\n    font-size: 30px; color: #b9c2cc; letter-spacing: 0.5px;\n  }\n  /* Timeline: 24s total. Brisk holds, fast fades. */\n  @keyframes pop {\n    0% { opacity: 0; transform: translateY(60px) scale(0.96); }\n    8% { opacity: 1; transform: translateY(0) scale(1); }\n    92% { opacity: 1; transform: translateY(0) scale(1); }\n    100% { opacity: 0; transform: translateY(-40px) scale(1.01); }\n  }\n  @keyframes popHold {\n    0% { opacity: 0; transform: translateY(60px) scale(0.96); }\n    10% { opacity: 1; transform: translateY(0) scale(1); }\n    100% { opacity: 1; transform: translateY(0) scale(1); }\n  }\n  .s1 { animation: pop 2.4s linear 0s 1 both; }\n  .s2 { animation: pop 3.0s linear 2.4s 1 both; }\n  .s3 { animation: pop 3.4s linear 5.4s 1 both; }\n  .s4 { animation: pop 3.4s linear 8.8s 1 both; }\n  .s5 { animation: pop 3.0s linear 12.2s 1 both; }\n  .s6 { animation: pop 3.0s linear 15.2s 1 both; }\n  .s7 { animation: pop 3.0s linear 18.2s 1 both; }\n  .s8 { animation: popHold 2.8s linear 21.2s 1 both; }\n  .w1 { display: inline-block; animation: wordup 0.5s ease-out 0.5s 1 both; }\n  .w2 { display: inline-block; animation: wordup 0.5s ease-out 0.9s 1 both; }\n  .w3 { display: inline-block; animation: wordup 0.5s ease-out 1.3s 1 both; }\n  @keyframes wordup {\n    0% { opacity: 0; transform: translateY(50px); }\n    100% { opacity: 1; transform: translateY(0); }\n  }\n</style>\n</head>\n<body>\n  <div class=\"stage\">\n    <div class=\"scene s1\">\n      <div class=\"kicker\">Heads up, Broward</div>\n      <div class=\"big gold\">August 3.</div>\n    </div>\n    <div class=\"scene s2\">\n      <div class=\"big\">Financing a Florida condo <span class=\"gold\">gets harder.</span></div>\n    </div>\n    <div class=\"scene s3\">\n      <div class=\"mid\">Fannie Mae and Freddie Mac are retiring the fast track condo loan review.</div>\n    </div>\n    <div class=\"scene s4\">\n      <div class=\"mid\">Every conventional condo loan will get a <span class=\"gold\">full building review.</span></div>\n    </div>\n    <div class=\"scene s5\">\n      <div class=\"stack\"><span class=\"w1\">Budget.</span><br><span class=\"w2 gold\">Reserves.</span><br><span class=\"w3\">Paperwork.</span></div>\n    </div>\n    <div class=\"scene s6\">\n      <div class=\"mid\">Buying? <span class=\"gold\">Read the reserve study first.</span></div>\n    </div>\n    <div class=\"scene s7\">\n      <div class=\"mid\">Own in a solid building? Your paperwork just became a <span class=\"gold\">selling feature.</span></div>\n    </div>\n    <div class=\"scene s8\">\n      <img class=\"endlogo\" src=\"../../assets/phr_logo_white.png\" alt=\"Prestige Heritage Realty\">\n      <div class=\"tagline\">Straight answers. <span class=\"gold\">Deep roots.</span></div>\n      <div class=\"rule\"></div>\n      <div style=\"height:52px\"></div>\n      <div class=\"compliance\">Roger Averbuj, Broker | Prestige Heritage Realty | (954) 663-8461</div>\n    </div>\n  </div>\n</body>\n</html>\n",

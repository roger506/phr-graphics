{"slug": "condo-loan-deadline", "card": {"html": "<!DOCTYPE html><html><head><meta charset=\"utf-8\"><style>\n*{margin:0;padding:0;box-sizing:border-box}\nhtml{background:#0d1f33}html,body{width:1080px;height:1350px;overflow:hidden}\nbody{background:linear-gradient(160deg,#0d1f33 0%,#122c47 55%,#0d1f33 100%);font-family:Georgia,'Times New Roman',serif;color:#f5f1e8;display:flex;flex-direction:column;padding:64px 96px 60px}\n.logo{display:block;margin:0 auto;width:300px}\n.krow{margin-top:44px}\n.kicker{font-family:'Helvetica Neue',Arial,sans-serif;font-size:28px;letter-spacing:9px;color:#c5a55a;text-transform:uppercase;font-weight:600}\n.rule{width:120px;height:4px;background:#c5a55a;margin-top:24px}\n.hook{margin-top:34px}\n.line{font-size:92px;line-height:1.16;font-weight:bold;letter-spacing:-1px}\n.gold{color:#c5a55a}.muted{color:#8ba3bd}\n.sub{margin-top:40px;font-family:'Helvetica Neue',Arial,sans-serif;font-size:35px;line-height:1.5;color:#d9d2c2;max-width:830px}\n.spacer{flex:1}\n.foot{border-top:1px solid rgba(197,165,90,.45);padding-top:30px;display:flex;align-items:center;justify-content:space-between}\n.bn{font-size:36px;font-weight:bold;color:#f5f1e8;white-space:nowrap}\n.bs{font-family:'Helvetica Neue',Arial,sans-serif;font-size:20px;color:#c5a55a;letter-spacing:2.5px;text-transform:uppercase;margin-top:9px;white-space:nowrap}\n.ct{font-family:'Helvetica Neue',Arial,sans-serif;text-align:right;font-size:23px;color:#b8c4d0;line-height:1.6;white-space:nowrap}\n</style></head><body>\n<img class=\"logo\" src=\"../../assets/phr_logo_white.png\">\n<div class=\"krow\"><div class=\"kicker\">Florida Condo Buyers &amp; Sellers</div><div class=\"rule\"></div></div>\n<div class=\"hook\"><div class=\"line\">A new mortgage</div><div class=\"line\">rule hits</div><div class=\"line gold\">August 3.</div></div>\n<div class=\"sub\">Financing a Florida condo is about to get harder. Here is what it means for your building, and what to check before you buy or sell.</div>\n<div class=\"spacer\"></div>\n<div class=\"foot\"><div><div class=\"bn\">Roger Averbuj</div><div class=\"bs\">Broker &middot; Prestige Heritage Realty</div></div><div class=\"ct\">(954) 663-8461<br>Davie &middot; Broward County, FL</div></div>\n</body></html>", "width": 1080, "height": 1350}, "video": {"html": "<!DOCTYPE html><html><head><meta charset=\"utf-8\"><style>\n*{margin:0;padding:0;box-sizing:border-box}\nhtml{background:#0d1f33}html,body{width:1080px;height:1920px;overflow:hidden}\nbody{background:linear-gradient(170deg,#0d1f33 0%,#122c47 55%,#0d1f33 100%);font-family:Georgia,'Times New Roman',serif;color:#f5f1e8}\n#stage{position:absolute;inset:0}\n.el{position:absolute;left:90px;right:90px;opacity:0;will-change:transform,opacity}\n.kicker{font-family:'Helvetica Neue',Arial,sans-serif;font-size:33px;letter-spacing:11px;color:#c5a55a;text-transform:uppercase;font-weight:600}\n.big{font-size:90px;font-weight:bold;line-height:1.14;letter-spacing:-1px}\n.mid{font-size:66px;font-weight:bold;line-height:1.22}\n.gold{color:#c5a55a}.muted{color:#8ba3bd}\n.chip{display:inline-block;background:rgba(197,165,90,.14);border:2px solid #c5a55a;border-radius:18px;padding:30px 40px;font-family:'Helvetica Neue',Arial,sans-serif;font-size:50px;font-weight:700;color:#f5f1e8}\n.rule{height:5px;background:#c5a55a;width:140px}\n.foot{font-family:'Helvetica Neue',Arial,sans-serif;font-size:29px;color:#8ba3bd;letter-spacing:2px}\n#logo{position:absolute;left:50%;width:520px;transform:translateX(-50%)}\n#vig{position:absolute;inset:0;background:radial-gradient(ellipse at 50% 42%,transparent 55%,rgba(0,0,0,.28) 100%);pointer-events:none}\n</style></head><body><div id=\"stage\">\n<img class=\"el\" id=\"logoTop\" src=\"../../assets/phr_logo_white.png\" style=\"left:50%;right:auto;top:120px;width:300px;margin-left:-150px\">\n<div class=\"el kicker\" id=\"k1\" style=\"top:470px\">Florida Condo Owners</div>\n<div class=\"el rule\" id=\"r1\" style=\"top:530px\"></div>\n<div class=\"el big\" id=\"h1\" style=\"top:590px\">Financing a</div>\n<div class=\"el big\" id=\"h2\" style=\"top:710px\">Florida condo</div>\n<div class=\"el big gold\" id=\"h3\" style=\"top:900px\">gets harder Aug 3.</div>\n\n<div class=\"el mid\" id=\"s2a\" style=\"top:560px\">Fannie and Freddie<br>retire the fast-track<br>condo review.</div>\n<div class=\"el\" id=\"s2b\" style=\"top:1180px\"><span class=\"chip\">Full review now required</span></div>\n\n<div class=\"el mid\" id=\"s3a\" style=\"top:520px\">Buildings with thin<br>reserves can become<br>hard to finance.</div>\n<div class=\"el mid gold\" id=\"s3b\" style=\"top:1180px\">That pushes prices<br>down.</div>\n\n<div class=\"el mid\" id=\"s4a\" style=\"top:520px\">Buyers: ask for the<br>reserve study before<br>you offer.</div>\n<div class=\"el mid\" id=\"s4b\" style=\"top:980px\">Sellers in strong<br>buildings: your<br>paperwork is now<br>a selling point.</div>\n\n<img class=\"el\" id=\"logoEnd\" src=\"../../assets/phr_logo_white.png\" style=\"left:50%;right:auto;top:560px;width:560px;margin-left:-280px\">\n<div class=\"el\" id=\"e1\" style=\"top:1060px;text-align:center;font-size:62px;font-weight:bold\">Roger Averbuj</div>\n<div class=\"el foot\" id=\"e2\" style=\"top:1160px;text-align:center\">BROKER &middot; PRESTIGE HERITAGE REALTY</div>\n<div class=\"el\" id=\"e3\" style=\"top:1240px;text-align:center;font-family:'Helvetica Neue',Arial,sans-serif;font-size:50px;color:#c5a55a;font-weight:700\">(954) 663-8461</div>\n<div class=\"el foot\" id=\"e4\" style=\"top:1350px;text-align:center\">Straight answers. Deep roots.</div>\n<div id=\"vig\"></div></div>\n<script>\nfunction cl(x,a,b){return Math.max(a,Math.min(b,x))}function ez(x){return 1-Math.pow(1-x,3)}\nfunction sh(id,t,t0,d,t1,od){var e=document.getElementById(id);var p=cl((t-t0)/d,0,1),k=ez(p),o=k,y=(1-k)*55;if(t1!==undefined){var q=cl((t-t1)/od,0,1),kq=ez(q);o=o*(1-kq);y=y-kq*35}e.style.opacity=o;e.style.transform='translateY('+y+'px)'}\nfunction pp(id,t,t0,d,t1,od){var e=document.getElementById(id);var p=cl((t-t0)/d,0,1),k=ez(p),o=k,s=.86+.14*k;if(t1!==undefined){var q=cl((t-t1)/od,0,1);o=o*(1-ez(q))}e.style.opacity=o;e.style.transform='scale('+s+')'}\nwindow.seek=function(t){\nsh('logoTop',t,.05,.5,3.6,.5);sh('k1',t,.15,.5,3.6,.5);sh('r1',t,.25,.5,3.6,.5);\nsh('h1',t,.5,.5,3.6,.5);sh('h2',t,.9,.5,3.6,.5);sh('h3',t,1.4,.6,3.6,.5);\nsh('s2a',t,4.2,.6,8.0,.5);pp('s2b',t,5.2,.5,8.0,.5);\nsh('s3a',t,8.5,.6,12.3,.5);sh('s3b',t,9.8,.6,12.3,.5);\nsh('s4a',t,12.8,.6,17.2,.5);sh('s4b',t,14.2,.6,17.2,.5);\nsh('logoEnd',t,17.6,.6);sh('e1',t,18.2,.5);sh('e2',t,18.6,.5);sh('e3',t,19.0,.5);sh('e4',t,19.6,.5);\n}\nwindow.seek(0)\n</script></body></html>", "width": 1080, "height": 1920, "fps": 25, "duration": 22.0}}